//! 手动测试地址计算
#![cfg(not(target_os = "none"))]

use page_table_generic::*;
use crate::mocks::*;

#[test]
fn test_manual_address() {
    let target_vaddr: VirtAddr = 0xfffff00000000000usize.into();
    println!("目标虚拟地址: {:?}, 原始值: {:#x}", target_vaddr, target_vaddr.raw());

    // 尝试使用更小的地址进行测试
    let simple_vaddr: VirtAddr = 0x10000000usize.into();
    println!("简单虚拟地址: {:?}, 原始值: {:#x}", simple_vaddr, simple_vaddr.raw());

    let mut pg = PageTable::<T4kL4, Fram4k>::new(Fram4k).unwrap();

    // 使用简单的地址进行映射
    let result = pg.map(&MapConfig {
        vaddr: simple_vaddr,
        paddr: 0x0000usize.into(),
        size: 0x2000,
        pte: PteImpl(0),
        allow_huge: false,
        flush: false,
    });

    match result {
        Ok(_) => println!("映射成功"),
        Err(e) => println!("映射失败: {:?}", e),
    }

    println!("\n映射后的有效条目:");
    let mut count = 0;
    for p in pg.walk_valid() {
        println!("l: {}, va: {:?}, pte: {:?}", p.level, p.vaddr, p.pte);
        count += 1;
    }
    println!("总条目数: {}", count);

    // 测试高地址是否导致问题
    let high_vaddr: VirtAddr = 0xffff800000000000usize.into();
    println!("\n尝试高地址: {:?}, 原始值: {:#x}", high_vaddr, high_vaddr.raw());

    let mut pg2 = PageTable::<T4kL4, Fram4k>::new(Fram4k).unwrap();

    let result2 = pg2.map(&MapConfig {
        vaddr: high_vaddr,
        paddr: 0x0000usize.into(),
        size: 0x2000,
        pte: PteImpl(0),
        allow_huge: false,
        flush: false,
    });

    match result2 {
        Ok(_) => println!("高地址映射成功"),
        Err(e) => println!("高地址映射失败: {:?}", e),
    }
}